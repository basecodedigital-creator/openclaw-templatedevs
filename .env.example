# ====================================
# .env.example — Template de Credenciais
# Copie para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env
# ====================================

# TELEGRAM
TELEGRAM_BOT_TOKEN=seu_token_aqui          # Obter em @BotFather no Telegram
TELEGRAM_CHAT_ID=seu_chat_id_aqui          # Seu ID pessoal no Telegram

# OPENROUTER (Modelos de IA)
OPENROUTER_API_KEY=sk-or-...               # https://openrouter.ai/keys

# GEMINI (Geração de imagens — nano-banana skill)
GEMINI_API_KEY=AIza...                     # https://aistudio.google.com/apikey

# SUPABASE (Sistema externo — Dyad/Lovable)
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...               # Opcional, para operações admin

# GATEWAY OPENCLAW
GATEWAY_AUTH_TOKEN=gerar_token_aleatorio   # openssl rand -hex 24

# ELEVENLABS (TTS — opcional)
ELEVENLABS_API_KEY=sk_...                  # https://elevenlabs.io
